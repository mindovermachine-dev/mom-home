---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="About" title="Mind over Machine" subtitle="The Foundation for Regenerative Software Development" />

  <Features
    title="Mission"
    columns={1}
    items={[
      {
        title: 'A commercial non-profit foundation',
        description:
          'Our mission is to explore and share regenerative approaches to software development that create a net positive long-term value for people and the planet.',
      },
    ]}
  />

  <Features
    title="Three Pillars"
    columns={3}
    items={[
      {
        title: 'Think Tank',
        description:
          'Research, analysis and dissemination of long-term systems thinking and regenerative principles within disciplines related to or derived from software and software development',
      },
      {
        title: 'Laboratory',
        description: 'Development of software, tools and methods that demonstrate regenerative principles in practice.',
      },
      {
        title: 'Community of Practice',
        description:
          'Facilitation of a community of practice for practitioners, researchers, students and decision-makers with the aim of promoting regenerative software, software development and socio-technological understanding.',
      },
    ]}
  />
</Layout>
