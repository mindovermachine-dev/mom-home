---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Services"
    title="Think tank and Laboratory services for regenerative software"
    subtitle="Advise, inspiration and hands-on support for teams that want better software outcomes over the long run."
  />

  <Features2
    title="How we can help"
    columns={2}
    items={[
      {
        title: 'Inspirational Talks',
        description:
          'What does "regenerative" mean - in context of software development. How can it be applied in practice? What are the benefits? We offer talks and keynotes to inspire and inform your organization on regenerative software development.',
      },
      {
        title: 'Delivery practice coaching',
        description:
          'Coaching on trunk-based development, shift-left quality practices, collaborative AI involvment, participatory design, No-estimates, feature-complete individual component releases and sustainable delivery flows.',
      },
      {
        title: 'Architecture and systems guidance',
        description:
          'Collaborative guidance for software architecture and design decisions with long-term system health in mind. Understand the systemic implications of decisions and move towards a socio-technical alignment.',
      },
      {
        title: 'Facilitated workshops and hackathons',
        description:
          'Facilitation of hands-on sessions to explore old ideas in new settings, run tutorials, solve real-world problems.',
      },
      {
        title: 'Laboratory experiments',
        description: 'Small pilot engagements to test new ways of working before scaling across the organization.',
      },
      {
        title: 'Flow and value stream analysis',
        description:
          'Analysis of your software delivery flow and value stream to identify _muda_, _mura_, and _muri_ to start your continuous improvement endeavor.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start a conversation',
        href: '/contact',
      },
    ]}
    title="Need practical support?"
    subtitle="Tell us where you are and what you are trying to improve."
  />
</Layout>
