---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Talk with Mind over Machine"
    subtitle="Reach out if you want to collaborate, host an event, or discuss service engagement."
  />

  <Features2
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'hello@mindovermachine.dk',
        icon: 'tabler:mail',
      },
      {
        title: 'Website',
        description: 'www.mindovermachine.dk',
        icon: 'tabler:world',
      },
      {
        title: 'GitHub',
        description: 'github.com/mindovermachine-dev',
        icon: 'tabler:brand-github',
      },
      {
        title: 'LinkedIn',
        description: 'linkedin.com/company/mindovermachine',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  />
</Layout>
