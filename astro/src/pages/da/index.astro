---
import Layout from '~/layouts/PageLayout.astro';
import Logo from '~/components/Logo.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Mind over Machine',
  ignoreTitleTemplate: true,
  description: 'En fond for regenerativ softwareudvikling gennem essays, events og services.',
};
---

<Layout metadata={metadata}>
  <div class="flex justify-center pt-6 md:pt-10">
    <Logo class="h-20 w-auto md:h-28" width={560} />
  </div>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Essays & Journals',
        href: '/da/essays/',
      },
      {
        text: 'Tjenester',
        href: '/da/services/',
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Mind over Machine visual' }}
  >
    <Fragment slot="title">
      Mind over Machine
      <span class="text-accent dark:text-white">Regenerativ software i praksis</span>
    </Fragment>

    <Fragment slot="subtitle">
      Vi er en non-profit fond, der samler en <b>tænketank</b>, et <b>laboratorium</b> og et <b>praksisfællesskab</b>.
      Vores mission er at udforske og dele regenerative tilgange og principper for softwareudvikling, som skaber en
      langsigtet, balanceret værdi for mennesker, samfund og verden. Vi tror på, at software kan være en kraft for det
      gode, når det udvikles og anvendes med omtanke og systemisk forståelse.
    </Fragment>
  </Hero>

  <Features
    id="focus"
    tagline="What we do"
    title="Three pillars of our work"
    items={[
      {
        title: 'Tænketank:',
        subtitle: 'Nytænkning og formidling',
        description:
          'Vi udvikler, analyserer, forsker og publicerer gratis materiale om regenerative softwareudvikling, systemtænkning, etik og langsigtede balancerede praksisser.',
        icon: 'tabler:book',
        callToAction: {
          text: 'Udforsk essays',
          href: '/da/essays/',
        },
      },
      {
        title: 'Praksisfællesskab:',
        subtitle: 'Legitim perifær deltagelse',
        description:
          'Vi arrangerer events og samtaler, hvor praktikere tester idéer, deler lærdomme og formerer en bedre softwarekultur.',
        icon: 'tabler:users-group',
        callToAction: {
          text: 'Udforsk aktiviteter',
          href: '/da/events/',
        },
      },
      {
        title: 'Laboratorium:',
        subtitle: 'Eksperimenter og medlemsengagement',
        description:
          'Vi tester antagelser og hypoteser om regenerative principper i samarbejde med medlemmer og akademia.',
        icon: 'tabler:flask',
        callToAction: {
          text: 'Udforsk laboratoriumstjenester',
          href: '/da/services/',
        },
      },
    ]}
  />

  <BlogLatestPosts
    title="Seneste essays"
    information="Nylige tekster fra Mind over Machine"
    linkText="Se alle essays"
    linkUrl="/da/essays/"
    locale="da"
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kontakt os',
        href: '/da/contact/',
      },
    ]}
    title="Soeger I en regenerativ vej for jeres softwareorganisation?"
    subtitle="Lad os udforske den sammen."
  />
</Layout>
