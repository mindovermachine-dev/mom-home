---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Mød Mind over Machine"
    subtitle="Ræk ud hvis du vil samarbejde, arrangere en begivenhed eller er interesseret i at få hjælp."
  />

  <Features2
    columns={2}
    items={[
      {
        title: 'Email',
        callToAction: {
          text: 'hey@mindovermachine.dk',
          href: 'mailto:hey@mindovermachine.dk',
        },
        icon: 'tabler:mail',
      },
      {
        title: 'Website',
        icon: 'tabler:world',
        callToAction: {
          text: 'www.mindovermachine.dk',
          href: 'https://www.mindovermachine.dk',
        },
      },
      {
        title: 'GitHub',
        callToAction: {
          text: '@mindovermachine-dev',
          href: 'https://github.com/mindovermachine-dev',
        },
        icon: 'tabler:brand-github',
      },
      {
        title: 'LinkedIn',
        icon: 'tabler:brand-linkedin',
        callToAction: {
          text: '@mindovermachine',
          href: 'https://linkedin.com/company/mindovermachine',
        },
      },
    ]}
  />
</Layout>
