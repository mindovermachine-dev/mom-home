---
import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import { findImage } from '~/utils/images';
import { blogPostRobots, findLocalizedPostWithFallback } from '~/utils/blog';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import { getLocalizedFallbackSlugs } from '~/lib/i18n/fallback-routes';
import type { MetaData } from '~/types';

export async function getStaticPaths() {
  const slugs = await getLocalizedFallbackSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const requestedSlug = Astro.params.slug ?? '';
const { post, usedLocale } = await findLocalizedPostWithFallback({
  slug: requestedSlug,
  locale: 'da',
});

if (!post) {
  return Astro.rewrite(requestedSlug.replace(/^\/+|\/+$/g, '') ? `/${requestedSlug.replace(/^\/+|\/+$/g, '')}/` : '/');
}

const isFallbackToEnglish = post && usedLocale === 'en';
const image = post ? ((await findImage(post.image)) as ImageMetadata | string | undefined) : undefined;
const url = post ? getCanonical(`/da/${trimLeadingSlash(getPermalink(post.permalink, 'post'))}`) : undefined;

const postMetadata =
  post && url
    ? (merge(
        {
          title: post.title,
          description: post.excerpt,
          robots: {
            index: blogPostRobots?.index,
            follow: blogPostRobots?.follow,
          },
          openGraph: {
            type: 'article',
            ...(image
              ? {
                  images: [
                    {
                      url: image,
                      width: (image as ImageMetadata)?.width,
                      height: (image as ImageMetadata)?.height,
                    },
                  ],
                }
              : {}),
          },
        },
        { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
      ) as MetaData)
    : undefined;

function trimLeadingSlash(value: string): string {
  return value.startsWith('/') ? value.slice(1) : value;
}
---

{
  postMetadata && url && (
    <Layout metadata={postMetadata} localeFallback={isFallbackToEnglish ? 'da' : undefined}>
      <SinglePost post={{ ...post, image }} url={url} locale="da">
        {post.Content && <post.Content />}
      </SinglePost>
      <ToBlogLink locale="da" />
      <RelatedPosts post={post} locale="da" />
    </Layout>
  )
}
