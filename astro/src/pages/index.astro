---
import Layout from '~/layouts/PageLayout.astro';
import Logo from '~/components/Logo.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Mind over Machine',
  ignoreTitleTemplate: true,
  description: 'A foundation for regenerative software development through essays, events, and services.',
};
---

<Layout metadata={metadata}>
  <div class="flex justify-center pt-6 md:pt-10">
    <Logo class="h-20 w-auto md:h-28" width={560} />
  </div>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Read essays',
        href: '/essays/',
      },
      {
        text: 'Explore services',
        href: '/services/',
      },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Mind over Machine visual' }}
  >
    <Fragment slot="title">
      Mind over Machine
      <span class="text-accent dark:text-white">Regenerative software in practice</span>
    </Fragment>

    <Fragment slot="subtitle">
      We are a non-profit foundation combining a <b>think tank</b>, a <b>laboratory</b>, and a <b
        >community of practice</b
      >. Our mission is to explore and share regenerative approaches to software development that create a net positive
      long-term value for people and the planet.
    </Fragment>
  </Hero>

  <Features
    id="focus"
    tagline="What we do"
    title="Three pillars of our work"
    items={[
      {
        title: 'Think tank:',
        subtitle: 'Thought leadership',
        description:
          'We devlop, analyse, reserch and publish open end free materials about regenerative software development, system thinking, ethics, and long-term healthy development practices.',
        icon: 'tabler:book',
        callToAction: {
          text: 'Explore essays',
          href: '/essays/',
        },
      },
      {
        title: 'Community of Practice:',
        subtitle: 'Legitimate peripheral participation',
        description:
          'We run events and conversations where practitioners test ideas, share learnings, and shape better software culture.',
        icon: 'tabler:users-group',
        callToAction: {
          text: 'Explore CoP activities',
          href: '/events/',
        },
      },
      {
        title: 'Laboratory:',
        subtitle: 'Experiments and membership engagement',
        description:
          'We test assumptions and hypotheses about regenerative principles in collaborative circles with members and academia.',
        icon: 'tabler:flask',
        callToAction: {
          text: 'Explore laboratory services',
          href: '/services/',
        },
      },
    ]}
  />

  <BlogLatestPosts
    title="Latest essays"
    information="Recent writing from Mind over Machine"
    linkText="See all essays"
    linkUrl="/essays/"
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contact us',
        href: '/contact',
      },
    ]}
    title="Looking for a regenerative path for your software organization?"
    subtitle="Let us explore it together."
  />
</Layout>
