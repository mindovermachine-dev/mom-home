---
// import '@fontsource-variable/inter';
import '@fontsource-variable/raleway';
import '@fontsource-variable/oswald';
import '@fontsource-variable/literata';
import '@fontsource-variable/roboto-mono';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata (serif)
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    /* Brand palette */
    --mom-sandstone: #f5ebe0;
    --mom-forest-green: #1b4331;
    --mom-terracotta: #d08c60;
    --mom-olive-green: #606c38;
    --mom-sage-green: #95d5b2;
    --mom-midnight-teal: #003049;
    --mom-midnight-forest: #011401;
    --mom-ether-blue: #669bbc;
    --mom-ochre-yellow: #e9c46a;
    --mom-slate-gray: #457b9d;

    /* AstroWind */

    --aw-font-sans: 'Raleway Variable';
    --aw-font-serif: 'Literata Variable';
    --aw-font-heading: 'Oswald Variable';
    --aw-font-mono: 'Roboto Mono Variable';

    --aw-color-primary: var(--mom-ether-blue);
    --aw-color-secondary: var(--mom-terracotta);
    --aw-color-accent: rgb(22, 108, 26);

    --aw-color-text-heading: var(--mom-midnight-forest);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: var(--mom-sandstone);

    --aw-color-bg-page-dark: var(--mom-midnight-forest);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    /* --aw-font-sans: 'Raleway Variable', sans-serif;
    --aw-font-serif: 'Raleway Variable', serif;
    --aw-font-heading: 'Oswald Variable', sans-serif;*/

    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: var(--mom-midnight-forest);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
