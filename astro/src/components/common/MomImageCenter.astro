---
import type { ImageMetadata } from 'astro';
import Image from '~/components/common/Image.astro';

export interface Props {
  src: string | ImageMetadata;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="mx-auto my-8 w-[min(100%,768px)]">
  <Image
    src={src}
    alt={alt}
    width={768}
    widths={[480, 768, 1000]}
    sizes="(max-width: 768px) 100vw, 768px"
    class="block w-full !mx-0 rounded-md"
  />
  <figcaption class="!mx-0 mt-3 !w-full !text-left text-sm text-muted dark:text-slate-400">
    {caption}
  </figcaption>
</figure>
