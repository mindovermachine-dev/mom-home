{
  "name": "Lean Crowd Manifest",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "gh ext install devx-cafe/gh-insitu && gh insitu run post-create",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/npm-packages:1": {
      "packages": [
        "cspell",
        "markdownlint-cli2",
        "prettier",
        "@cspell/dict-da-dk"
      ]
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "github.copilot",
        "github.copilot-chat",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-danish",
        "unifiedjs.vscode-mdx",
        "mhutchie.git-graph"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        }
      }
    }
  },
  "mounts": [
    "source=${localEnv:HOME},target=/localhome,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  }
}
